name: CI Pipeline

on:
  push:
    branches: [ "main" ]
  pull_request:
    branches: [ "main" ]

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install dependencies
        run: |
          pip install --upgrade pip setuptools wheel
          pip install -r requirements.txt
          pip show pytest

      - name: Lint
        run: |
          pip install ruff
          ruff check .

      - name: Run tests
        run: pytest tests/ -v
        env:
          MLFLOW_TRACKING_URI: "file:./mlruns"  